{
  "manifest_version": 3,
  "name": "Forsyth Schools Portal",
  "version": "1.1.3",
  "description": "Your Forsyth schools dashboard in one click—ClassLink, Infinite Campus, Canvas, and district tools, personalized and private.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "Forsyth Schools Portal"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://campus.forsyth.k12.ga.us/*",
    "https://launchpad.classlink.com/*",
    "https://forsyth.instructure.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://campus.forsyth.k12.ga.us/*"],
      "js": ["content/infinite-campus.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://launchpad.classlink.com/*"],
      "js": ["content/classlink.js"],
      "run_at": "document_idle"
    }
  ]
}
